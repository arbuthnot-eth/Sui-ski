{
	"name": "sui.ski",
	"version": "0.1.1",
	"description": ".Sui Key-In .SKI - Once, Everywhere",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/arbuthnot-eth/Sui-ski"
	},
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "npx wrangler deploy",
		"tail": "wrangler tail",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"set:contenthash": "bun run scripts/set-suins-contenthash.ts",
		"obsidian:daily": "bun run scripts/obsidian.ts daily",
		"obsidian:git": "bun run scripts/obsidian.ts git",
		"obsidian:progress": "bun run scripts/obsidian.ts progress",
		"obsidian:open": "bun run scripts/obsidian.ts open",
		"obsidian:all": "bun run scripts/obsidian.ts all",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/",
		"format": "biome format --write src/"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.26.0",
		"@mysten/sui": "^2.4.0",
		"@mysten/suins": "^1.0.0",
		"agents": "^0.4.1",
		"hono": "^4.11.7",
		"tiny-invariant": "^1.3.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@cloudflare/workers-types": "^4.20260116.0",
		"@ika.xyz/sdk": "^0.2.7",
		"@playwright/test": "^1.58.2",
		"@types/bun": "^1.3.6",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"wrangler": "^4.66.0"
	}
}
